# Copy these keys into the Streamlit Community Cloud "Secrets" panel
# (Manage app → Settings → Secrets). Locally, you can put them into
# `.streamlit/secrets.toml` (which is gitignored) instead of `.env`.
#
# Free Copernicus Marine registration:
#   https://marine.copernicus.eu/

COPERNICUSMARINE_SERVICE_USERNAME = "your_username_here"
COPERNICUSMARINE_SERVICE_PASSWORD = "your_password_here"
